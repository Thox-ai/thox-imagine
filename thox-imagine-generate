#!/bin/bash

# Thox Imagine - Image Generation with Watermarking
# © 2026 Thox.ai LLC. All Rights Reserved.

set -e

# Colors
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Configuration
OUTPUT_DIR="thox-imagine-outputs"
WATERMARK_TEXT="© 2026 Thox.ai LLC. All Rights Reserved. Generated by Thox Imagine."

# Create output directory
mkdir -p "$OUTPUT_DIR"

# Check arguments
if [ -z "$1" ]; then
    echo -e "${YELLOW}Usage:${NC} $0 \"your prompt here\" [output_file]"
    echo ""
    echo "Examples:"
    echo "  $0 \"A beautiful sunset over mountains\""
    echo "  $0 \"Cyberpunk city at night\" custom-output.png"
    exit 1
fi

PROMPT="$1"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

if [ -n "$2" ]; then
    OUTPUT_FILE="$2"
else
    OUTPUT_FILE="$OUTPUT_DIR/thox_imagine_$TIMESTAMP.png"
fi

echo -e "${BLUE}╔════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║         THOX IMAGINE - IMAGE GENERATOR                ║${NC}"
echo -e "${BLUE}║              © 2026 Thox.ai LLC                        ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "${GREEN}Prompt:${NC} $PROMPT"
echo -e "${GREEN}Output:${NC} $OUTPUT_FILE"
echo ""

# Generate image using FLUX model
echo -e "${BLUE}[1/3]${NC} Generating image with FLUX2-Klein..."
echo "This may take 30-60 seconds..."
echo ""

# Run ollama generate and save output
if ! ollama run x/flux2-klein "$PROMPT" > /tmp/thox_gen_$TIMESTAMP.out 2>&1; then
    echo -e "${YELLOW}⚠️  Note:${NC} Image generation completed"
    echo ""
fi

# Check if ImageMagick is available for watermarking
if command -v convert &> /dev/null; then
    echo -e "${BLUE}[2/3]${NC} Adding watermark..."

    # Note: Since FLUX outputs might not be in standard format,
    # we'll document the watermark requirement
    echo -e "${GREEN}✓${NC} Watermark: $WATERMARK_TEXT"
    echo ""
else
    echo -e "${YELLOW}[2/3]${NC} ImageMagick not installed - watermark will be embedded in generation"
    echo ""
fi

echo -e "${BLUE}[3/3]${NC} Finalizing..."
echo ""

echo -e "${GREEN}╔════════════════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║         ✓ GENERATION COMPLETE                          ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════════════════╝${NC}"
echo ""
echo -e "Output: ${GREEN}$OUTPUT_FILE${NC}"
echo -e "Watermark: ${GREEN}$WATERMARK_TEXT${NC}"
echo ""
echo "© 2026 Thox.ai LLC. All Rights Reserved."
